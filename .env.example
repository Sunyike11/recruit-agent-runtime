# LLM provider compatible with OpenAI Chat Completions.
# Fill values locally; never commit real secrets.
OPENAI_API_KEY=
OPENAI_API_BASE=

# Hugging Face cache/token are optional for embedding downloads.
HF_TOKEN=
HF_HOME=
HUGGINGFACE_HUB_TOKEN=

# Recruit-Graph local configuration.
RECRUIT_GRAPH_MODE=skill
RECRUIT_AGENT_PROJECT_ROOT=
RECRUIT_AGENT_DATA_DIR=./data
RECRUIT_AGENT_CHROMA_DIR=./chroma_db
RECRUIT_AGENT_LLM_MODEL=deepseek-chat
RECRUIT_AGENT_LLM_TEMPERATURE=0
RECRUIT_AGENT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RECRUIT_AGENT_RETRIEVER_TOP_K=5
RECRUIT_AGENT_MATCHER_LOOP_LIMIT=2
RECRUIT_AGENT_DOTENV_PATH=.env

# Optional legacy feature flags used by smoke tests.
RECRUIT_AGENT_SKILL_BACKED_GRAPH_VARIANT=
